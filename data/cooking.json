{
    "recipes": [
        {
            "id": "c-001",
            "title": "たこ焼き",
            "date": "2026-05-10",
            "tags": ["たこ焼き", "粉もん", "鉄板焼き"],
            "ingredients": [
                "【生地】",
                "小麦粉： 125g",
                "かつおだし： 5g",
                "醤油： 4g",
                "卵： 半分",
                "水： 500ml",
                "【具材】",
                "たこ： 適量",
                "ねぎ頭： 適量",
                "天かす： 適量",
                "紅生姜： 適量",
                "【トッピング】",
                "たこ焼きソース： お好みのもの（※イカリソースは微妙かも）"
            ],
            "instructions": [
                "<strong>生地作り：</strong>ボウルに小麦粉、かつおだし、醤油、卵、水を入れ、ダマがなくなるまでよく混ぜ合わせます。",
                "<strong>焼く：</strong>たこ焼き器をしっかりと熱して油をひき、生地を流し入れます。たこ、ねぎ頭、天かす、紅生姜などの具材を入れます。",
                "<strong>仕上げ：</strong>生地の端が焼けてきたら、竹串などでくるくると回しながら丸くこんがりと焼き上げます。",
                "<strong>ソース：</strong>焼き上がったら、お好みのたこ焼きソースなどをかけて完成です。<br><span class=\"text-xs text-blue-600 block mt-1\">こだわりポイント： たこ焼きソース選びは重要です（イカリソース以外がおすすめ）。</span>"
            ]
        },
        {
            "id": "c-002",
            "title": "担々麺のタレ",
            "date": "2026-05-13",
            "tags": ["担々麺", "タレ", "中華"],
            "ingredients": [
                "芝麻醤（チーマージャン）： 大さじ1",
                "醤油： 小さじ2",
                "黒酢： 小さじ1",
                "砂糖： 小さじ1",
                "鶏ガラスープ（お湯で溶いたもの）： 大さじ2",
                "辣油： 小さじ1/2〜",
                "花椒粉： 耳かき1〜2杯程度"
            ],
            "instructions": [
                "<strong>タレ作り：</strong>器に芝麻醤、醤油、黒酢、砂糖を入れてよく混ぜ合わせます。",
                "<strong>スープ合わせ：</strong>鶏ガラスープ（お湯で溶いたもの）を加えてさらに混ぜ、タレを伸ばします。",
                "<strong>仕上げ：</strong>辣油と花椒粉をお好みの量加えて完成です。茹でた麺にかけてお召し上がりください。"
            ]
        },
        {
            "id": "c-003",
            "title": "マッシュポテト",
            "date": "2026-05-13",
            "tags": ["マッシュポテト", "じゃがいも", "付け合わせ"],
            "ingredients": [
                "じゃがいも： 400g",
                "牛乳： 大さじ4",
                "有塩バター： 約27g",
                "塩： 小さじ1/2弱（約2.5g）",
                "こしょう： 少々"
            ],
            "instructions": [
                "<strong>茹でる：</strong>じゃがいもの皮をむいて適当な大きさに切り、水から約20分茹でます。竹串がスッと通るまで柔らかくします。",
                "<strong>潰す：</strong>茹で上がったらお湯を切り、熱いうちにマッシャーなどで滑らかに潰します。",
                "<strong>仕上げ：</strong>バター、牛乳、塩、こしょうを加えてよく混ぜ合わせたら完成です。"
            ]
        }
    ]
}
